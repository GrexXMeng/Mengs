    Callback = function(state)
        if not ScriptLoaded or IsLoadingConfig then return end
        NoclipEnabled = state

        if NoclipConnection then
            NoclipConnection:Disconnect()
            NoclipConnection = nil
        end

        if state then
            OriginalCollision = {}
            local char = LocalPlayer.Character
            if char then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        OriginalCollision[v] = v.CanCollide
                    end
                end
            end

            NoclipConnection = game:GetService("RunService").Heartbeat:Connect(function()
                local char = LocalPlayer.Character
                if not char then return end
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                    end
                end
            end)

        else
            local char = LocalPlayer.Character
            if not char then
                OriginalCollision = {}
                return
            end

            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")

            if hrp then
                local currentY = hrp.AssemblyLinearVelocity.Y
                local safeY = math.clamp(currentY, -50, 0)
                hrp.AssemblyLinearVelocity = Vector3.new(0, safeY, 0)
                hrp.AssemblyAngularVelocity = Vector3.zero
            end

            local anchoredParts = {}
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") and not v.Anchored then
                    anchoredParts[v] = true
                    v.Anchored = true
                end
            end

            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then
                    if OriginalCollision[v] ~= nil then
                        v.CanCollide = OriginalCollision[v]
                    else
                        v.CanCollide = true
                    end
                end
            end

            task.defer(function()
                if not char or not char.Parent then return end
                for v, _ in pairs(anchoredParts) do
                    if v and v.Parent then
                        v.Anchored = false
                    end
                end

                if humanoid and humanoid.Parent then
                    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
            end)

            OriginalCollision = {}
        end
    end

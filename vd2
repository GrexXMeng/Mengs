-- [[ Auto Generator ]]
local AutoGenEnabled = false
local KillerEscapeDist = 30
local CurrentGen = nil
local LastFireTime = 0
local RepairEvent = ReplicatedStorage.Remotes.Generator.RepairEvent

local SCPCache = {}
local SCPCacheTimer = 0

local function GetGeneratorPoints(genModel)
    local points = {}
    pcall(function()
        for _, obj in pairs(genModel:GetChildren()) do
            if obj.Name:find("GeneratorPoint") and obj:IsA("BasePart") then
                table.insert(points, obj)
            end
        end
    end)
    return points
end

local function IsGenDone(gen)
    local done = false
    pcall(function()
        local progress = gen:GetAttribute("RepairProgress") or gen:GetAttribute("ProgressRepair") or 0
        done = progress >= 100
    end)
    return done
end

local function GetSCPs()
    local now = tick()
    if now - SCPCacheTimer < 3 then return SCPCache end
    SCPCache = {}
    SCPCacheTimer = now
    local mapFolder = workspace:FindFirstChild("Map")
    if not mapFolder then return SCPCache end
    pcall(function()
        for _, folder in pairs(mapFolder:GetChildren()) do
            for _, obj in pairs(folder:GetChildren()) do
                if obj:IsA("Model") and obj.Name:lower():find("^scp") then
                    table.insert(SCPCache, obj)
                end
            end
        end
    end)
    return SCPCache
end

local function IsKillerNearby(position, radius)
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local isKiller = char:FindFirstChild("Lookscriptkiller", true) ~= nil
        if isKiller and (hrp.Position - position).Magnitude <= radius then
            return true
        end
    end
    for _, model in pairs(GetSCPs()) do
        if model and model.Parent then
            local pos
            pcall(function() pos = model:GetPivot().Position end)
            if pos and (pos - position).Magnitude <= radius then
                return true
            end
        end
    end
    return false
end

local function GetAllGenerators()
    local gens = {}
    local added = {}
    local mapFolder = workspace:FindFirstChild("Map")
    if not mapFolder then return gens end
    pcall(function()
        for _, v in pairs(mapFolder:GetDescendants()) do
            if v.Name == "Generator" and v:IsA("Model") and not added[v] then
                if v.Parent and v.Parent.Name == "Generator" then continue end
                added[v] = true
                table.insert(gens, v)
            end
        end
    end)
    return gens
end

local function GetBestGenerator()
    local hrp = GetRoot()
    if not hrp then return nil end
    local gens = GetAllGenerators()
    local bestGen = nil
    local bestDist = math.huge
    for _, gen in pairs(gens) do
        if IsGenDone(gen) then continue end
        local pos
        pcall(function() pos = gen:GetPivot().Position end)
        if not pos then continue end
        if IsKillerNearby(pos, KillerEscapeDist) then continue end
        local dist = (hrp.Position - pos).Magnitude
        if dist < bestDist then
            bestDist = dist
            bestGen = gen
        end
    end
    return bestGen
end

local function TeleportToGen(gen)
    local hrp = GetRoot()
    if not hrp then return end
    local points = GetGeneratorPoints(gen)
    if #points > 0 then
        local bestPoint = nil
        local bestDist = math.huge
        for _, point in pairs(points) do
            local d = (hrp.Position - point.Position).Magnitude
            if d < bestDist then
                bestDist = d
                bestPoint = point.Position
            end
        end
        if bestPoint then
            hrp.CFrame = CFrame.new(bestPoint + Vector3.new(0, 2, 0))
            return
        end
    end
    local pos
    pcall(function() pos = gen:GetPivot().Position end)
    if pos then
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 2, 0))
    end
end

local function IsNearPoint(gen)
    local hrp = GetRoot()
    if not hrp then return false end
    local points = GetGeneratorPoints(gen)
    for _, point in pairs(points) do
        if (hrp.Position - point.Position).Magnitude <= 5 then
            return true
        end
    end
    return false
end

local function StopRepairGen(gen)
    if not gen then return end
    local points = GetGeneratorPoints(gen)
    for _, point in pairs(points) do
        pcall(function() RepairEvent:FireServer(point, false) end)
    end
end

local function StopRepair()
    StopRepairGen(CurrentGen)
    CurrentGen = nil
end


local function NewLabel(key, adornee)
    local bg = Instance.new("BillboardGui")
    bg.Name = "ESP_" .. key
    bg.AlwaysOnTop = true
    bg.Size = UDim2.new(0, 120, 0, 20)
    bg.StudsOffset = Vector3.new(0, 3, 0)
    bg.Adornee = adornee
    bg.Parent = ESPFolder

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.TextScaled = false
    label.TextSize = 11
    label.Font = Enum.Font.GothamBold
    label.Text = ""
    label.Parent = bg

    return bg, label
end

local function GetESP(key, target, color)
    if not ESPObjects[key] then
        local hl = Instance.new("Highlight")
        hl.Name = "Meng_Outline"
        hl.FillTransparency = 1
        hl.OutlineTransparency = 0
        hl.OutlineColor = color
        hl.Adornee = target
        hl.Parent = ESPFolder

        local gui, label = NewLabel(key, target)
        ESPObjects[key] = { hl = hl, gui = gui, label = label }
    end

    local e = ESPObjects[key]
    e.hl.OutlineColor = color
    e.hl.Adornee = target
    e.hl.Enabled = true
    e.gui.Adornee = target
    e.gui.Enabled = true
    return e
end

local function HideESP(key)
    if ESPObjects[key] then
        local e = ESPObjects[key]
        if e.hl then e.hl.Enabled = false end
        if e.gui then e.gui.Enabled = false end
        if e.label then e.label.Text = "" end
    end
end

local function FindObjects(objType)
    local list = {}
    local keywords = {
        Generator = {"Generator"},
        Hook      = {"Hook"},
        Pallet    = {"Pallet", "Palletwrong"},
        Gate      = {"Gate", "ExitGate"}
    }

    local targetKeywords = keywords[objType]
    local added = {}
    local skipDescendantsOf = {}

    local mapFolder = workspace:FindFirstChild("Map")
    if not mapFolder then return list end

    pcall(function()
        for _, v in pairs(mapFolder:GetDescendants()) do
            if not v:IsA("Model") then continue end

            local skip = false
            for _, parent in pairs(skipDescendantsOf) do
                if v:IsDescendantOf(parent) then
                    skip = true
                    break
                end
            end
            if skip then continue end

            for _, kw in pairs(targetKeywords) do
                if v.Name == kw and not added[v] then
                    added[v] = true
                    table.insert(skipDescendantsOf, v)
                    table.insert(list, v)
                    break
                end
            end
        end
    end)

    return list
end

local function UpdateESP()
    if not Settings.Master then
        for k in pairs(ESPObjects) do HideESP(k) end
        return
    end

    local now = tick()
    if now - lastUpdate < UPDATE_INTERVAL then return end
    lastUpdate = now

    local cam = workspace.CurrentCamera

    -- player ESP
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local key = "ply_" .. p.Name
        local char = p.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if hrp then
            local isKiller = char:FindFirstChild("Lookscriptkiller", true) ~= nil
            local shouldDraw = (isKiller and Settings.Killers) or (not isKiller and Settings.Survivors)

            if shouldDraw then
                local color = isKiller and Colors.Killer or Colors.Survivor
                local e = GetESP(key, char, color)

                local dist = math.floor((hrp.Position - cam.CFrame.Position).Magnitude)
                local hum = char:FindFirstChildOfClass("Humanoid")

                local parts = {}
                if Settings.ShowName then table.insert(parts, p.Name) end
                if Settings.ShowDistance then table.insert(parts, dist .. "m") end
                if Settings.ShowHealth and hum then table.insert(parts, math.floor(hum.Health) .. " HP") end

                e.label.Text = table.concat(parts, " | ")
                e.label.TextColor3 = color
                e.gui.Enabled = true
            else
                HideESP(key)
            end
        else
            HideESP(key)
        end
    end

    -- object ESP
    local objTypes = {
        {"Generator", Settings.Generators, Colors.Generator},
        {"Hook",      Settings.Hooks,      Colors.Hook},
        {"Pallet",    Settings.Pallets,    Colors.Pallet},
        {"Gate",      Settings.Gates,      Colors.Gate},
    }

    if now - CacheTimer > 5 then
        ObjCache = {}
        CacheTimer = now
    end

    for _, data in pairs(objTypes) do
        local typeName, enabled, col = data[1], data[2], data[3]
        if not ObjCache[typeName] then ObjCache[typeName] = FindObjects(typeName) end

        for i, obj in pairs(ObjCache[typeName]) do
            local key = typeName .. "_" .. i
            if enabled and obj and obj.Parent then
                local e = GetESP(key, obj, col)

                local worldPos
                pcall(function()
                    worldPos = obj:IsA("Model") and obj:GetPivot().Position or obj.Position
                end)
                if not worldPos then continue end

                local dist = math.floor((worldPos - cam.CFrame.Position).Magnitude)

                local parts = {}
                if Settings.ShowName then table.insert(parts, typeName) end
                if Settings.ShowDistance then table.insert(parts, dist .. "m") end

                e.label.Text = table.concat(parts, " | ")
                e.label.TextColor3 = col
                e.gui.Enabled = true
            else
                HideESP(key)
            end
        end
    end

    if Settings.SCPs then
        local scps = GetSCPs()
        for i, model in pairs(scps) do
            if not model or not model.Parent then continue end
            local key = "scp_" .. i
            local e = GetESP(key, model, Colors.SCP)

            local worldPos
            pcall(function() worldPos = model:GetPivot().Position end)
            if not worldPos then continue end

            local dist = math.floor((worldPos - cam.CFrame.Position).Magnitude)
            local parts = {}
            if Settings.ShowName then table.insert(parts, "SCP") end
            if Settings.ShowDistance then table.insert(parts, dist .. "m") end

            e.label.Text = table.concat(parts, " | ")
            e.label.TextColor3 = Colors.SCP
            e.gui.Adornee = model
            e.gui.Enabled = true
        end
    end
end

local executorName = (identifyexecutor and identifyexecutor() or "Unknown")
local currentPlaceID = game.PlaceId
local currentUniverseID = game.GameId
local isVelocity = executorName:find("Velocity")

local scriptURL
if isVelocity then
    scriptURL = velocityOverrides[currentUniverseID] or velocityOverrides[currentPlaceID]
              or games[currentUniverseID] or games[currentPlaceID]
else
    scriptURL = games[currentUniverseID] or games[currentPlaceID]
end

if scriptURL then
    print("Meng Hub: Loading script for ID " .. (games[currentUniverseID] and "Universe" or "Place"))
    loadstring(game:HttpGet(scriptURL))()
else
    local msg = "\nMap not supported yet!\nPlaceId: " .. tostring(currentPlaceID) .. "\nUniverseId: " .. tostring(currentUniverseID)
    game.Players.LocalPlayer:Kick(msg)
    print(msg)
end
